{
  "name": "auto-commit-mate",
  "displayName": "ACM: Auto-Commit Mate++",
  "description": "AI-powered developer work-log, commit classifier, report generator, and productivity tracker. Automatically tracks, summarizes, and reports what you worked on.",
  "version": "2.0.0",
  "icon": "assets/extension-icon.png",
  "publisher": "Rahulnisanth",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Other",
    "SCM Providers"
  ],
  "activationEvents": [
    "onStartupFinished",
    "workspaceContains:.git"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "ACM: Auto-Commit Mate++",
      "properties": {
        "acm.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable/disable all ACM tracking",
          "scope": "machine"
        },
        "acm.githubUsername": {
          "type": "string",
          "default": "",
          "description": "GitHub username (non-sensitive). Token is stored securely in Secret Storage.",
          "scope": "machine"
        },
        "acm.additionalRepoPaths": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Additional Git repository paths to track (beyond VS Code workspace folders)",
          "scope": "machine"
        },
        "acm.commitIntervalMinutes": {
          "type": "number",
          "default": 30,
          "minimum": 1,
          "description": "Interval in minutes between auto-commit log snapshots",
          "scope": "machine"
        },
        "acm.idleThresholdMinutes": {
          "type": "number",
          "default": 5,
          "minimum": 1,
          "description": "Minutes of inactivity before marking the session as idle",
          "scope": "machine"
        },
        "acm.riskThresholdLines": {
          "type": "number",
          "default": 50,
          "minimum": 1,
          "description": "Number of uncommitted lines that trigger a risk alert",
          "scope": "machine"
        },
        "acm.riskThresholdMinutes": {
          "type": "number",
          "default": 60,
          "minimum": 1,
          "description": "Minutes without a commit before triggering a risk alert",
          "scope": "machine"
        },
        "acm.syncEnabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable automatic sync of work logs to GitHub Activity-Logger repo",
          "scope": "machine"
        },
        "acm.syncFrequencyHours": {
          "type": "number",
          "default": 24,
          "minimum": 1,
          "description": "How often (in hours) to auto-sync to GitHub",
          "scope": "machine"
        },
        "acm.logRetentionDays": {
          "type": "number",
          "default": 90,
          "minimum": 7,
          "description": "Number of days to retain local activity logs in ~/.acm/logs/",
          "scope": "machine"
        },
        "acm.showStartupPrompt": {
          "type": "boolean",
          "default": true,
          "description": "Show the ACM welcome prompt on VS Code startup",
          "scope": "machine"
        }
      }
    },
    "commands": [
      {
        "command": "acm.start",
        "title": "Start Auto-Committing",
        "category": "ACM"
      },
      {
        "command": "acm.stop",
        "title": "Stop Auto-Committing",
        "category": "ACM"
      },
      {
        "command": "acm.setInterval",
        "title": "Set Commit Interval",
        "category": "ACM"
      },
      {
        "command": "acm.generateDaily",
        "title": "Generate Daily Report",
        "category": "ACM"
      },
      {
        "command": "acm.generateWeekly",
        "title": "Generate Weekly Report",
        "category": "ACM"
      },
      {
        "command": "acm.generateMonthly",
        "title": "Generate Monthly Report",
        "category": "ACM"
      },
      {
        "command": "acm.generateAppraisal",
        "title": "Generate Appraisal Report",
        "category": "ACM"
      },
      {
        "command": "acm.askQuestion",
        "title": "Ask About My Work",
        "category": "ACM"
      },
      {
        "command": "acm.syncNow",
        "title": "Sync to GitHub Now",
        "category": "ACM"
      },
      {
        "command": "acm.viewLog",
        "title": "View Today's Activity Log",
        "category": "ACM"
      },
      {
        "command": "acm.clearCredentials",
        "title": "Clear Credentials",
        "category": "ACM"
      },
      {
        "command": "acm.openSettings",
        "title": "Open Settings",
        "category": "ACM"
      },
      {
        "command": "acm.openSidebar",
        "title": "Open Sidebar",
        "category": "ACM"
      },
      {
        "command": "acmSidebar.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "acmSidebar",
          "name": "AUTO-COMMIT MATE++",
          "icon": "$(clock)",
          "contextualTitle": "ACM Activity"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "acmSidebar.refresh",
          "when": "view == acmSidebar",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "compile": "node esbuild.js",
    "compile:prod": "node esbuild.js --production",
    "watch": "node esbuild.js --watch",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "pretest": "npm run compile",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@types/uuid": "^10.0.0",
    "@types/vscode": "^1.115.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "esbuild": "^0.25.3",
    "eslint": "^9.16.0",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "axios": "^1.7.9",
    "uuid": "^11.1.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Rahulnisanth/ACM.git"
  },
  "bugs": {
    "url": "https://github.com/Rahulnisanth/ACM/issues"
  },
  "license": "MIT",
  "keywords": [
    "git",
    "auto commit",
    "vscode extension",
    "productivity",
    "ai",
    "gemini",
    "work log",
    "report generator",
    "activity tracker"
  ]
}
